---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import HomeLogo from "../components/HomeLogo.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="home bg-[var(--brand-blue)] flex flex-col">
    <canvas
      id="binary-canvas"
      class="fixed inset-0 w-full h-full pointer-events-none"
      style="z-index: 1;"></canvas>

    <div class="min-h-screen flex flex-col relative" style="z-index: 2;">
      <Header />
      <div class="w-full grow flex flex-col items-center justify-center logo">
        <HomeLogo
          class="text-white w-full h-auto max-w-4xl px-4 drop-shadow-2xl"
        />

        <div class="animated-entry subtitle text-center">
          <span
            class="text-white text-lg sm:text-2xl font-medium pt-3 tracking-widest font-sans uppercase"
            style="letter-spacing: 0.2em;"
          >
            DevOps & Software Engineer
          </span>
        </div>
      </div>
    </div>

    <Footer />

    <script>
      // ── Configuration ─────────────────────────────────
      const DENSITY = 10000; // Lower = more particles (pixels per particle)
      const SIZE_MIN = 10; // Min font size (px)
      const SIZE_MAX = 26; // Max font size (px)
      const OPACITY_MIN = 0.1; // Min opacity (0–1)
      const OPACITY_MAX = 0.35; // Max opacity (0–1)
      const SPEED_X = 0.2; // Horizontal drift range (±)
      const SPEED_Y_MIN = 0.1; // Min upward speed
      const SPEED_Y_MAX = 0.25; // Max upward speed
      const ROTATION_SPEED = 0.008; // Max rotation speed (±)
      // ─────────────────────────────────────────────────

      const canvas = document.getElementById(
        "binary-canvas",
      ) as HTMLCanvasElement;
      const ctx = canvas.getContext("2d")!;

      // Pre-render digit sprites at different sizes/opacities
      const spriteCache = new Map<string, HTMLCanvasElement>();

      function getSprite(
        char: string,
        size: number,
        opacity: number,
      ): HTMLCanvasElement {
        const key = `${char}-${size}-${opacity.toFixed(2)}`;
        if (spriteCache.has(key)) return spriteCache.get(key)!;

        const s = Math.ceil(size * 2);
        const off = document.createElement("canvas");
        off.width = s;
        off.height = s;
        const oc = off.getContext("2d")!;
        oc.font = `${size}px 'Inter Variable', monospace`;
        oc.fillStyle = `rgba(255, 255, 255, ${opacity})`;
        oc.textAlign = "center";
        oc.textBaseline = "middle";
        oc.fillText(char, s / 2, s / 2);
        spriteCache.set(key, off);
        return off;
      }

      interface Particle {
        x: number;
        y: number;
        vx: number;
        vy: number;
        sprite: HTMLCanvasElement;
        spriteSize: number;
        rotation: number;
        rotationSpeed: number;
      }

      let particles: Particle[] = [];

      function resize() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
      }

      function spawnParticles() {
        const count = Math.floor((canvas.width * canvas.height) / DENSITY);
        particles = [];
        spriteCache.clear();
        for (let i = 0; i < count; i++) {
          const size = Math.round(
            Math.random() * (SIZE_MAX - SIZE_MIN) + SIZE_MIN,
          );
          const opacity =
            Math.round(
              (Math.random() * (OPACITY_MAX - OPACITY_MIN) + OPACITY_MIN) * 100,
            ) / 100;
          const char = Math.random() > 0.5 ? "1" : "0";
          particles.push({
            x: Math.random() * canvas.width,
            y: Math.random() * canvas.height,
            vx: (Math.random() - 0.5) * SPEED_X * 2,
            vy: -(Math.random() * (SPEED_Y_MAX - SPEED_Y_MIN) + SPEED_Y_MIN),
            sprite: getSprite(char, size, opacity),
            spriteSize: Math.ceil(size * 2),
            rotation: Math.random() * Math.PI * 2,
            rotationSpeed: (Math.random() - 0.5) * ROTATION_SPEED * 2,
          });
        }
      }

      function animate() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        const w = canvas.width;
        const h = canvas.height;

        for (const p of particles) {
          p.x += p.vx;
          p.y += p.vy;
          p.rotation += p.rotationSpeed;

          if (p.y < -40) p.y = h + 40;
          if (p.x < -40) p.x = w + 40;
          if (p.x > w + 40) p.x = -40;

          const half = p.spriteSize / 2;
          ctx.save();
          ctx.translate(p.x, p.y);
          ctx.rotate(p.rotation);
          ctx.drawImage(p.sprite, -half, -half);
          ctx.restore();
        }

        requestAnimationFrame(animate);
      }

      resize();
      spawnParticles();
      animate();

      window.addEventListener("resize", () => {
        resize();
        spawnParticles();
      });
    </script>
  </body>
</html>
