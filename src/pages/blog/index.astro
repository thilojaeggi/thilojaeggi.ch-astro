---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import Header from "../../components/Header.astro";
import { SITE_TITLE } from "../../consts";

const posts = (await getCollection("blog")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Blog | ${SITE_TITLE}`}
			description="Thoughts, guides, and experiments from Thilo Jaeggi on DevOps, cloud computing, and software engineering."
		/>
		<style>
			.blog-main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.3s cubic-bezier(0.23, 1, 0.32, 1);
			}
			ul li:first-child {
				width: 100%;
				margin-bottom: 1rem;
				text-align: center;
			}
			ul li:first-child img {
				width: 100%;
			}
			ul li:first-child .title {
				font-size: 2.369rem;
			}
			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
				transition: transform 0.4s cubic-bezier(0.23, 1, 0.32, 1), box-shadow 0.4s cubic-bezier(0.23, 1, 0.32, 1);
			}
			ul li a {
				display: block;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
			}
			ul li a:hover h4 {
				color: var(--accent);
				transform: translateX(4px);
			}
			ul li a:hover .date {
				color: var(--accent);
			}
			ul li a:hover img {
				box-shadow: 0 12px 40px var(--glow-color);
				transform: translateY(-6px);
			}
			@media (max-width: 720px) {
				ul {
					gap: 0.5em;
				}
				ul li {
					width: 100%;
					text-align: center;
				}
				ul li:first-child {
					margin-bottom: 0;
				}
				ul li:first-child .title {
					font-size: 1.563em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="blog-main page-enter">
			<div class="mb-10">
				<h1 class="text-5xl font-bold tracking-tight">Blog</h1>
				<p class="text-[rgb(var(--gray))] text-lg mt-2">Thoughts, guides, and experiments.</p>
			</div>
			<section>
				<ul class="stagger-enter">
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									{post.data.heroImage && (
										<Image
											width={720}
											height={360}
											src={post.data.heroImage}
											alt={`Cover image for ${post.data.title}`}
										/>
									)}
									<h4 class="title">{post.data.title}</h4>
									<p class="date">
										<FormattedDate
											date={post.data.pubDate}
										/>
									</p>
								</a>
							</li>
						))
					}
					{posts.length === 0 && <p class="text-[rgb(var(--gray))] text-lg">No blog posts yet. Check back soon!</p>}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
