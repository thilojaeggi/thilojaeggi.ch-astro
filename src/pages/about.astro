---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";

// Date of birth (month is zero-based: 3 = April)
const dob = new Date(2004, 3, 16);
const today = new Date();
let years = today.getFullYear() - dob.getFullYear();
const hasHadBirthdayThisYear =
  today.getMonth() > dob.getMonth() ||
  (today.getMonth() === dob.getMonth() && today.getDate() >= dob.getDate());

if (!hasHadBirthdayThisYear) years--;
const age = years;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`About | ${SITE_TITLE}`} description={`Learn more about Thilo Jaeggi – a ${age}-year-old DevOps Engineer from Switzerland, SwissSkills silver medalist, and open-source contributor.`} />
  </head>
  <body class="flex flex-col min-h-screen">
    <Header />
    <main class="grow flex flex-col items-center justify-center p-4 page-enter">
      <div class="max-w-3xl mx-auto">
        <h1 class="text-5xl font-bold tracking-tight mb-8">About<span class="text-[var(--accent)]">.</span></h1>
        <div class="space-y-6 text-xl leading-relaxed text-[rgb(var(--gray-dark))]">
          <p>
            I'm a {age}-year-old <span class="font-semibold text-[rgb(var(--black))]">DevOps Engineer</span> from
            Switzerland, currently working at <span class="font-semibold text-[rgb(var(--black))]">PostFinance</span>.
          </p>

          <p>
            My passion for cloud technologies goes well beyond the workplace. In 2025,
            I earned the
            <span class="font-semibold text-[rgb(var(--black))]">silver medal</span> at the SwissSkills in Cloud
            Computing, a competition focused on AWS and Linux. Competing against some
            of the best talents in Switzerland helped me refine my expertise in cloud
            infrastructure and automation — an experience that continues to shape how
            I approach complex technical challenges.
          </p>

          <p>
            Outside of work, I enjoy exploring emerging trends in software and hardware,
            experimenting with <span class="font-semibold text-[rgb(var(--black))]">mixed reality</span>, and
            developing custom tech projects. I'm especially passionate about <span
              class="font-semibold text-[rgb(var(--black))]">open source</span>,
            where I contribute to the global tech community. Some of my most
            notable projects include
            <a
              href="https://github.com/thilojaeggi/WinGetty"
              target="_blank"
              rel="noopener noreferrer"
              class="link-premium font-semibold"
              >WinGetty</a>
            and
            <a
              href="https://github.com/thilojaeggi/Notely"
              target="_blank"
              rel="noopener noreferrer"
              class="link-premium font-semibold"
              >Notely</a>, both available on my
            <a
              href="https://github.com/thilojaeggi"
              target="_blank"
              rel="noopener noreferrer"
              class="link-premium font-semibold"
              >GitHub</a>.
          </p>

          <p>
            Whether through <span class="font-semibold text-[rgb(var(--black))]">AWS</span>, open-source
            development, or hands-on hardware projects, I'm always looking for new
            ways to innovate and push the boundaries of technology.
          </p>
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>
