---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import TechChip from "../components/TechChip.astro";

type Props = CollectionEntry<"projects">["data"];

const {
  title,
  description,
  client,
  year,
  technologies,
  links,
  stats,
  pubDate,
} = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <Header />
    <main class="w-full max-w-4xl mx-auto px-4 py-12 page-enter">
      <div
        class="h-full w-full max-w-4xl mx-auto"
        transition:name={`project-card-${title}`}
      >
        <div
          class="pb-4 w-full flex flex-col sm:flex-row items-start sm:items-center justify-between gap-2"
        >
          <h1
            class="text-5xl md:text-6xl font-bold w-fit text-[rgb(var(--black))] tracking-tight"
            transition:name={`project-title-${title}`}
          >
            {title}
          </h1>
          <div
            class="flex flex-row sm:flex-col items-center sm:items-end gap-2 sm:gap-0 text-[rgb(var(--gray))]"
          >
            {
              year && (
                <div class="w-fit" transition:name={`project-year-${title}`}>
                  <span class="text-sm font-medium">{year}</span>
                </div>
              )
            }
            {
              client && (
                <div class="w-fit" transition:name={`project-client-${title}`}>
                  <span class="text-sm">{client}</span>
                </div>
              )
            }
          </div>
        </div>
        <div>
          <div class="flex flex-wrap gap-3 mt-1 items-center">
            {
              stats &&
                stats.map((stat) => (
                  <div class="bg-[var(--chip-bg)] px-3 flex items-center py-2 rounded-lg border border-[var(--chip-border)]">
                    <span class="font-semibold text-sm text-[var(--chip-text)]">
                      {stat}
                    </span>
                  </div>
                ))
            }
          </div>

          {
            technologies && (
              <div class="flex flex-wrap gap-3 mt-4 mb-2">
                {technologies.map((tech) => (
                  <TechChip name={tech.name} icon={tech.icon} />
                ))}
              </div>
            )
          }

          <div class="flex flex-row items-center mt-6 gap-4">
            {
              links?.github && (
                <a
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-block transition-all duration-300 group active:scale-95"
                  href={links.github}
                  aria-label="GitHub Repository"
                >
                  <div class="transition-all duration-300 group-hover:-translate-y-1 group-hover:scale-105">
                    <svg
                      class="fill-[rgb(var(--black))] w-10 h-10"
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                    >
                      <path d="M10.9,2.1c-4.6,0.5-8.3,4.2-8.8,8.7c-0.6,5,2.5,9.3,6.9,10.7v-2.3c0,0-0.4,0.1-0.9,0.1c-1.4,0-2-1.2-2.1-1.9 c-0.1-0.4-0.3-0.7-0.6-1C5.1,16.3,5,16.3,5,16.2C5,16,5.3,16,5.4,16c0.6,0,1.1,0.7,1.3,1c0.5,0.8,1.1,1,1.4,1c0.4,0,0.7-0.1,0.9-0.2 c0.1-0.7,0.4-1.4,1-1.8c-2.3-0.5-4-1.8-4-4c0-1.1,0.5-2.2,1.2-3C7.1,8.8,7,8.3,7,7.6C7,7.2,7,6.6,7.3,6c0,0,1.4,0,2.8,1.3 C10.6,7.1,11.3,7,12,7s1.4,0.1,2,0.3C15.3,6,16.8,6,16.8,6C17,6.6,17,7.2,17,7.6c0,0.8-0.1,1.2-0.2,1.4c0.7,0.8,1.2,1.8,1.2,3 c0,2.2-1.7,3.5-4,4c0.6,0.5,1,1.4,1,2.3v3.3c4.1-1.3,7-5.1,7-9.5C22,6.1,16.9,1.4,10.9,2.1z" />
                    </svg>
                  </div>
                </a>
              )
            }

            {
              links?.website && (
                <a
                  class="transition-all duration-300 hover:text-[var(--accent)] font-semibold text-base text-[rgb(var(--black))] inline-flex items-center gap-1.5 group"
                  target="_blank"
                  rel="noopener noreferrer"
                  href={links.website}
                  aria-label={`Visit official site for ${title}`}
                >
                  Visit Official Site
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-4 h-4 transition-transform group-hover:translate-x-1"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M14 5l7 7m0 0l-7 7m7-7H3"
                    />
                  </svg>
                </a>
              )
            }
          </div>

          <div class="border-b border-[var(--card-border)] w-full mt-6"></div>
        </div>

        <div
          class="project-content text-lg max-w-4xl pt-6 text-[rgb(var(--gray-dark))] leading-relaxed"
        >
          <slot />
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>
