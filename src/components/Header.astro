---
import HomeLogo from "./HomeLogo.astro";
import HeaderLink from "./HeaderLink.astro";
import ThemeToggle from "./ThemeToggle.astro";
const { pathname } = Astro.url;
const isHome = pathname === "/";
---

<header class={`py-2 z-50 sticky top-0 px-4 ${isHome ? "bg-transparent" : "bg-[var(--brand-blue)]"}`}>
  <nav
    class="grid
  grid-cols-1
  sm:grid-cols-3
  items-center
  max-w-7xl
  mx-auto"
  >
    <div class="flex justify-center sm:justify-start">
      <a href="/">
        <HomeLogo
          isHeader={true}
          class={`h-14 md:h-18 w-auto text-white hover:text-gray-200 transition-colors ${isHome ? "hidden sm:block sm:invisible" : ""}`}
        />
      </a>
    </div>

    <div class="flex gap-5 md:gap-6 justify-center items-center text-white">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/projects">Projects</HeaderLink>
      <HeaderLink href="/blog">Blog</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
    </div>

    <div class="flex justify-center sm:justify-end pr-4">
      <ThemeToggle />
    </div>
  </nav>
</header>
